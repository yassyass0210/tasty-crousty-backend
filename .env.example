STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLIC_KEY=pk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_test_xxx (À configurer après de Stripe)

MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/tastycrousty

EMAIL_USER=contact@tastycrousty.com (Gmail)
EMAIL_PASSWORD=app-password-16-chars (App Password depuis Gmail)

# Twilio — SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Mailchimp — Email Marketing
MAILCHIMP_API_KEY=your_mailchimp_api_key (format: xxxxx-us1)
MAILCHIMP_LIST_ID=your_mailchimp_list_id

# SendGrid — Marketing Emails
SENDGRID_API_KEY=your_sendgrid_api_key (SG.xxxxx)
SENDGRID_FROM_EMAIL=contact@tastycrousty.com
SENDGRID_WELCOME_TEMPLATE_ID=d-xxxxx

NODE_ENV=production
FRONTEND_URL=https://tastycrousty.vercel.app
PORT=3001
